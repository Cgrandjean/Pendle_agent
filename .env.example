# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional: restrict bot to specific chat IDs (comma-separated)
# Get your chat ID by messaging @userinfobot or @RawDataBot on Telegram
# ALLOWED_CHAT_IDS=123456789,987654321

# Scan interval in minutes (default: 10) - silent scan, only alerts on spikes/thresholds
# SCAN_INTERVAL_MINUTES=10

# Default query for scheduled reports (default: "top 5 stable loops")
# DEFAULT_REPORT_QUERY=top 5 stable loops

# SQLite database path (default: data/loop_scout.db)
# DB_PATH=data/loop_scout.db

# Spike detection: alert when current yield > SMA * multiplier
# SPIKE_WINDOW=30         # number of past scans to average (30 scans × 10 min = 5h)
# SPIKE_MULTIPLIER=1.5    # ratio threshold (1.5 = 50% above average)
# SPIKE_MIN_YIELD=0.05    # ignore yields below 5%

# Webhook mode (HF Spaces): leave empty for local polling
# WEBHOOK_URL=https://your-space-name.hf.space
# WEBHOOK_PORT=7860
